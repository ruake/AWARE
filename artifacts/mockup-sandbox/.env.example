# ── Aware Portal Configuration ───────────────────────────────────
# All available environment variables with examples.
# Vite loads these at build time. Prefix must be VITE_ to be exposed to client code.

# === Data Source ===

# Mock mode: "true" (default) uses fast in-memory mock data — no network needed.
# Set to "false" to fetch from static JSON files in the repo or a remote API.
#
# Examples:
#   VITE_USE_MOCK=true   → local dev with bundled mock data (no server)
#   VITE_USE_MOCK=false  → fetch from VITE_API_BASE_URL
VITE_USE_MOCK=true

# API / data base URL (only used when VITE_USE_MOCK=false).
#
# ── Same-repo static files (GitHub Pages model)
#   Auto-detected default: {VITE_BASE_URL}/data
#   Dev:   /data/runs.json          (BASE_URL=/)
#   Prod:  /AWARE/data/runs.json    (BASE_URL=/AWARE/)
#
# ── External REST API
#   VITE_API_BASE_URL=https://api.example.com/v1
#
# ── CDN-hosted static files
#   VITE_API_BASE_URL=https://cdn.example.com/aware-data
#
# ── Custom path override
#   VITE_API_BASE_URL=/custom-data-path
VITE_API_BASE_URL=

# === Polling ===

# Interval (ms) for the live status poll. Clamped to [5000, 300000].
VITE_POLLING_INTERVAL_MS=30000

# === HTTP Client Resilience ===

# Request timeout in milliseconds (default: 10000, min: 2000)
VITE_REQUEST_TIMEOUT_MS=10000

# Maximum GET retry attempts for transient failures (5xx, 429, network).
# Each attempt uses exponential backoff with jitter. (default: 3)
VITE_MAX_RETRIES=3

# Base delay (ms) for retry backoff — doubles each attempt. (default: 1000)
# Attempt 1: 1000ms, Attempt 2: 2000ms, Attempt 3: 4000ms
VITE_RETRY_BASE_DELAY_MS=1000

# Cache busting: append ?_t={timestamp} to every request URL.
# true       → always on
# false      → always off
# <unset>    → auto: on in dev, off in production
VITE_CACHE_BUST=

# === Feature Flags ===

# Warn banner when mock data is active (default: true)
VITE_SHOW_MOCK_BANNER=true

# ─────────────────────────────────────────────────────────────────
# DEPLOYMENT PROFILES (reference — uncomment one block at a time)
# ─────────────────────────────────────────────────────────────────

# === 1. Local Development (mock data, no network needed) ===
# VITE_USE_MOCK=true
# VITE_API_BASE_URL=
# VITE_POLLING_INTERVAL_MS=30000
# VITE_REQUEST_TIMEOUT_MS=10000
# VITE_CACHE_BUST=true

# === 2. Local Development (real static files from /data) ===
# VITE_USE_MOCK=false
# VITE_API_BASE_URL=/data
# VITE_POLLING_INTERVAL_MS=15000
# VITE_CACHE_BUST=true

# === 3. GitHub Pages (static files in same repo) ===
# VITE_USE_MOCK=false
# # VITE_API_BASE_URL defaults to {BASE_URL}/data → /AWARE/data
# VITE_POLLING_INTERVAL_MS=60000
# VITE_CACHE_BUST=false

# === 4. Custom Domain + CDN ===
# VITE_USE_MOCK=false
# VITE_API_BASE_URL=https://cdn.mycompany.com/aware/v2
# VITE_POLLING_INTERVAL_MS=30000
# VITE_REQUEST_TIMEOUT_MS=15000
# VITE_MAX_RETRIES=3

# === 5. Aggressive Polling (demo / status page) ===
# VITE_USE_MOCK=false
# VITE_API_BASE_URL=/data
# VITE_POLLING_INTERVAL_MS=5000
# VITE_REQUEST_TIMEOUT_MS=5000

# === 6. High-Latency / Unreliable Network ===
# VITE_USE_MOCK=false
# VITE_API_BASE_URL=https://slow-api.example.com
# VITE_REQUEST_TIMEOUT_MS=30000
# VITE_MAX_RETRIES=5
# VITE_RETRY_BASE_DELAY_MS=2000

# === 7. Disconnected / Offline Demo ===
# VITE_USE_MOCK=true
# # Uses bundled mock data — zero network calls
