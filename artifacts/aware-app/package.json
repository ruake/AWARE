{
  "name": "@workspace/aware-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "npx simple-git-hooks",
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "presplit": "node scripts/split-test-results.mjs",
    "prebuild": "node scripts/validate-data.mjs && node ../../scripts/validate-config.mjs && node scripts/split-test-results.mjs",
    "build": "vite build --config vite.config.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test",
    "test:e2e:install": "playwright install chromium --with-deps",
    "test:puppeteer": "node scripts/run-puppeteer.mjs",
    "test:http": "node scripts/run-http.mjs",
    "test:all-e2e": "pnpm test:e2e:ci; pnpm test:puppeteer; pnpm test:http",
    "extract:branch-data": "node scripts/extract-branch-data.js",
    "discover:tests": "node scripts/discover-all.mjs",
    "validate:data": "node scripts/validate-data.mjs",
    "badge": "node scripts/generate-badge.mjs",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "audit": "pnpm audit --prod --audit-level high",
    "audit:all": "pnpm audit --audit-level moderate",
    "verify": "pnpm run typecheck && pnpm run lint && pnpm run format && pnpm run test"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm verify"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@replit/vite-plugin-cartographer": "catalog:",
    "@replit/vite-plugin-dev-banner": "catalog:",
    "@replit/vite-plugin-runtime-error-modal": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "4.1.9",
    "clsx": "catalog:",
    "date-fns": "^3.6.0",
    "esbuild": "^0.24.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.10.1",
    "lucide-react": "catalog:",
    "prettier": "^3.8.3",
    "react": "catalog:",
    "react-dom": "catalog:",
    "recharts": "^2.15.2",
    "simple-git-hooks": "2.13.1",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.60.1",
    "vite": "catalog:",
    "vitest": "^4.1.9",
    "wouter": "^3.5.0"
  },
  "sideEffects": false,
  "dependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/user-event": "14.6.1",
    "framer-motion": "catalog:",
    "js-yaml": "^4.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  }
}
