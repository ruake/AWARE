{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aware.dev/schemas/test-results.json",
  "title": "Test Results Data Contract",
  "description": "Each run maps to an array of TestResult objects. REQUIRED fields must always be present. OPTIONAL fields may be absent.",
  "type": "object",
  "patternProperties": {
    "^run_[a-z0-9_]+$": {
      "type": "array",
      "items": { "$ref": "#/definitions/TestResult" }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "TestResult": {
      "type": "object",
      "required": ["id", "name", "status", "duration", "category", "suite", "assertions", "evidence"],
      "properties": {
        "id":                { "type": "string", "description": "Unique result ID" },
        "name":              { "type": "string", "description": "Human-readable test name" },
        "status":            { "type": "string", "enum": ["PASS", "FAIL"] },
        "duration":          { "type": "number", "description": "Duration in milliseconds" },
        "category":          { "type": "string", "description": "Category grouping" },
        "suite":             { "type": "string", "description": "Suite/spec file name" },
        "error":             { "type": "string", "description": "Error message (OPTIONAL — only on failure)" },
        "assertions": {
          "type": "array",
          "description": "List of assertion results (REQUIRED — empty array if none)",
          "items": { "$ref": "#/definitions/TestAssertionResult" }
        },
        "evidence": {
          "description": "HTTP request/response evidence (REQUIRED)",
          "$ref": "#/definitions/TestEvidence"
        },
        "filmstrip": {
          "type": "array",
          "description": "Screenshot filmstrip frames (OPTIONAL)",
          "items": { "$ref": "#/definitions/FilmstripFrame" }
        }
      }
    },
    "TestAssertionResult": {
      "type": "object",
      "required": ["assertion", "expected", "actual", "passed"],
      "properties": {
        "assertion": { "type": "string" },
        "expected":  { "type": "string" },
        "actual":    { "type": "string" },
        "passed":    { "type": "boolean" }
      }
    },
    "TestEvidence": {
      "type": "object",
      "required": ["request", "response", "assertions"],
      "properties": {
        "request":  { "$ref": "#/definitions/HttpRequest" },
        "response": { "$ref": "#/definitions/HttpResponse" },
        "assertions": {
          "type": "array",
          "items": { "$ref": "#/definitions/TestAssertionResult" }
        }
      }
    },
    "HttpRequest": {
      "type": "object",
      "required": ["method", "url", "headers"],
      "properties": {
        "method":  { "type": "string", "description": "HTTP method" },
        "url":     { "type": "string", "format": "uri", "description": "Request URL" },
        "headers": { "type": "object", "description": "Request headers key-value map", "additionalProperties": { "type": "string" } },
        "body":    { "type": "string", "description": "Request body (OPTIONAL)" }
      }
    },
    "HttpResponse": {
      "type": "object",
      "required": ["status", "headers"],
      "properties": {
        "status":  { "type": "integer", "description": "HTTP status code" },
        "headers": { "type": "object", "description": "Response headers key-value map", "additionalProperties": { "type": "string" } },
        "body":    { "type": "string", "description": "Response body (OPTIONAL)" },
        "cookies": {
          "type": "array",
          "description": "Response cookies (OPTIONAL)",
          "items": { "$ref": "#/definitions/TestCookie" }
        }
      }
    },
    "TestCookie": {
      "type": "object",
      "required": ["name", "value"],
      "properties": {
        "name":     { "type": "string" },
        "value":    { "type": "string" },
        "domain":   { "type": "string" },
        "path":     { "type": "string" },
        "httpOnly": { "type": "boolean" },
        "secure":   { "type": "boolean" }
      }
    },
    "FilmstripFrame": {
      "type": "object",
      "required": ["id", "label", "dataUri"],
      "properties": {
        "id":        { "type": "string" },
        "label":     { "type": "string" },
        "dataUri":   { "type": "string", "description": "Base64 data URI of screenshot" },
        "timestamp": { "type": "number" }
      }
    }
  }
}
