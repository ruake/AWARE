# =============================================================================
# A.W.A.R.E. — Environment Variables
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For GitHub Actions: set these as repository secrets or variables
# at Settings → Secrets and variables → Actions.
#
# See SETUP.md for the full fork-and-configure guide.
# =============================================================================


# ── GitHub Actions (automatically provided by GitHub — do NOT set manually) ──
# GITHUB_TOKEN          provided by Actions runtime; needs `contents:write` + `actions:write`
# GITHUB_SHA            current commit SHA
# GITHUB_REPOSITORY     owner/repo slug (e.g. your-org/aware)
# GITHUB_REF_NAME       branch name


# ── Dashboard / Static site ──────────────────────────────────────────────────

# Path prefix for GitHub Pages deployment.
# Set to the repository name if hosting at https://<org>.github.io/<repo>
# e.g. BASE_PATH=/aware
# Leave blank (or /) for a custom domain.
BASE_PATH=/

# API endpoint for the dashboard
VITE_API_ENDPOINT=

# OpenAI API key for the AI proxy (server-side, used in vite.config.ts)
OPENAI_API_KEY=

# Local dev server port (default: 5173 for Vite, 5000 on Replit)
PORT=5000


# ── AI Copilot (optional) ─────────────────────────────────────────────────────

# LLM provider: "mock" (offline), "openai" (OpenAI-compatible), or "webllm" (local WebGPU)
# Defaults to "mock" if unset — the Copilot page still works without an API key.
VITE_LLM_PROVIDER=mock

# OpenAI API key — required only when VITE_LLM_PROVIDER=openai
# Get yours at https://platform.openai.com/api-keys
# For GitHub Actions: add as a repository secret named VITE_LLM_API_KEY
VITE_LLM_API_KEY=

# OpenAI-compatible base URL (optional — defaults to https://api.openai.com/v1)
# Override for Azure OpenAI, local proxies (LM Studio, Ollama), or other providers.
VITE_LLM_API_URL=

# Model name (optional — defaults to gpt-4o-mini)
VITE_LLM_MODEL=gpt-4o-mini


# ── Akamai (optional — only needed for live property management via API) ──────

# Akamai EdgeGrid credentials — only required if you use the Akamai API
# integration (not needed for basic dashboard + test observability use).
# See: https://developer.akamai.com/api/getting-started
AKAMAI_ACCESS_TOKEN=
AKAMAI_CLIENT_TOKEN=
AKAMAI_CLIENT_SECRET=
AKAMAI_HOST=


# ── Notifications (optional) ──────────────────────────────────────────────────

# Slack incoming webhook URL — enables failure/regression notifications.
# Create one at https://api.slack.com/apps → Incoming Webhooks
# For GitHub Actions: add as a repository secret named SLACK_WEBHOOK_URL
SLACK_WEBHOOK_URL=

# PagerDuty routing key — enables on-call alerting for PROD failures.
# For GitHub Actions: add as a repository secret named PAGERDUTY_ROUTING_KEY
PAGERDUTY_ROUTING_KEY=
